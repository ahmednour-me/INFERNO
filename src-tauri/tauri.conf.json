{
  "productName": "INFERNO USB Forge",
  "version": "1.0.0",
  "identifier": "dev.inferno.usb-forge",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "INFERNO USB Forge",
        "width": 1280,
        "height": 820,
        "minWidth": 960,
        "minHeight": 640,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "decorations": true,
        "transparent": false
      }
    ],
    "security": {
      "csp": null
    },
    "trayIcon": {
      "iconPath": "icons/icon.png",
      "iconAsTemplate": true
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "appimage"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Utility",
    "shortDescription": "Professional bootable USB forge for Linux",
    "longDescription": "INFERNO USB Forge — A powerful Linux desktop tool for creating bootable USB drives. Supports single ISO flashing, Ventoy multi-boot, LUKS encryption, S.M.A.R.T. diagnostics, drive cloning, hash verification, and secure erase.",
    "linux": {
      "deb": {
        "depends": ["udisks2", "smartmontools", "coreutils", "libwebkit2gtk-4.1-0", "libgtk-3-0"]
      },
      "appimage": {
        "bundleMediaFramework": true
      }
    }
  }
}
